# ── Production checklist (Vercel) ─────────────────────────────────────────────
# 1. Link Upstash Redis / Vercel KV → sets KV_REST_API_URL + KV_REST_API_TOKEN
# 2. Set OAUTH_STATE_SECRET (long random string)
# 3. Set AUTH_CALLBACK_BASE_URL=https://www.tipsyfoxescapes.ca (public app origin, no path)
# 4. Register OAuth redirect URIs in each provider console:
#      https://www.tipsyfoxescapes.ca/api/auth/oauth/{google|facebook|github}/callback
# 5. Set provider client IDs/secrets below
# 6. After deploy, GET /api/health — ok:true and authStore:"kv" when persistence is wired
#
# Production (Vercel): link Upstash Redis / Vercel KV so auth survives cold starts and OAuth bundle split.
# After linking, Vercel sets KV_REST_API_URL and KV_REST_API_TOKEN on the project automatically.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Public app origin only (no /api/auth/oauth/... path). Code appends the callback path once.
# Base URL the *browser* uses to reach the OAuth callback. Must match the public app origin.
# Local (Vite :5173): http://localhost:5173
# Vercel (all-in-one): https://www.tipsyfoxescapes.ca  (same URL users open; /api runs as serverless)
# Register the exact redirect URI in Google Cloud Console, e.g.:
#   http://localhost:5173/api/auth/oauth/google/callback
#   https://your-app.vercel.app/api/auth/oauth/google/callback
AUTH_CALLBACK_BASE_URL=http://localhost:5173

# Signed OAuth state (required on Vercel). Use a long random string in production.
OAUTH_STATE_SECRET=change-me-in-production

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook Login (register redirect: {AUTH_CALLBACK_BASE_URL}/api/auth/oauth/facebook/callback)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Meta Webhooks → Callback URL https://your-host.example/webhook (legacy: …/api/webhooks/facebook)
# Verify token must match FACEBOOK_VERIFY_TOKEN in Meta Developer → Webhooks.
FACEBOOK_VERIFY_TOKEN=

# GitHub OAuth (register redirect: {AUTH_CALLBACK_BASE_URL}/api/auth/oauth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub repository webhooks (POST /api/webhooks/github) — not the OAuth client secret.
GITHUB_WEBHOOK_SECRET=

# OpenAI API key — powers the server-side "/api/inspiration/generate" endpoint.
# Leave blank to fall back to deterministic mock data (app still works without it).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Email delivery for verification emails (POST-signup "click to activate" flow).
# Priority order: Resend (if RESEND_API_KEY set) → SMTP (if SMTP_USER + SMTP_PASS set) → console log (dev only).
#
# Option 1 — Resend REST API (recommended for Vercel; free tier at https://resend.com):
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#   EMAIL_FROM=Tipsy Fox Escapes <noreply@yourdomain.com>
#
# Option 2 — SMTP (Gmail App Password or any SMTP server):
#   Generate an App Password at myaccount.google.com → Security → App passwords.
#   SMTP_HOST=smtp.gmail.com        (default; omit for Gmail)
#   SMTP_PORT=587                   (default; use 465 for SSL)
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   (16-char App Password — NOT your Gmail login password)
#   EMAIL_FROM=Your Name <you@gmail.com>
#
# Option 3 — Leave all blank (dev fallback): URL is printed to the console and shown on screen.
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Tipsy Fox Escapes <noreply@tipsyfoxescapes.com>

# Comma-separated emails that always get full access without a paid subscription (ops / owner accounts).
ADMIN_EMAILS=your-admin@example.com

# Optional salt for hashing client IPs in usage-ledger.json (change in production).
USAGE_HASH_SALT=change-me-in-production

# Dev / manual fulfillment (admin accounts only): POST /api/billing/activate-test with body
# { "activationKey": "<this value>", "roomsToAdd": 10 } while signed in as an admin user (adds room slots; not time-based).
SUBSCRIPTION_ACTIVATION_KEY=dev-change-me

# Square payments (customer checkout for room packs). Create an app at https://developer.squareup.com
#
# Required for checkout (hosted payment links + /api/billing/plans "configured"):
#   SQUARE_ACCESS_TOKEN   — Square API access token (Production or Sandbox)
#   SQUARE_LOCATION_ID    — Location id from Square Dashboard → Locations
#
# Required for in-card Web Payments SDK (optional if you only use hosted checkout):
#   SQUARE_APPLICATION_ID — Application ID from Square Developer Dashboard
#
# Environment (must match access token + application id; application id wins if set):
#   SQUARE_ENVIRONMENT=sandbox     — local dev with sandbox credentials
#   SQUARE_ENVIRONMENT=production  — live site (e.g. tipsyfoxescapes.ca on Vercel)
# Sandbox application ids start with "sandbox-"; production ids start with "sq0idp-" or "sq0idb-".
# Web Payments SDK loads production JS only when the application id is production (auto-detected).
#
# Vercel: Project → Settings → Environment Variables → Production & Preview.
# Enable "Runtime" (not Build-only). After changes, redeploy. Do NOT use SQUARE_ACCED_TOKEN (typo).
#
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
# Public URL where users land after checkout (production: https://www.tipsyfoxescapes.ca)
APP_PUBLIC_URL=http://localhost:5173
# Webhook (optional for dev; recommended in production for automatic fulfillment):
# Subscribe to payment.updated in Square Developer Dashboard.
# Notification URL must match exactly.
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-host.example/api/billing/square/webhook

# Optional: legacy manual fulfillment when not using Square (server-to-server).
BILLING_WEBHOOK_SECRET=
