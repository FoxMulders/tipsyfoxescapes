{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && npm ci --prefix backend && npm ci --prefix frontend",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist",
  "env": {
    "SKIP_VERSION_BUMP": "1",
    "DATA_DIR": "/tmp/erb-data",
    "OAUTH_GOOGLE_ENABLED": "1",
    "AUTH_CALLBACK_BASE_URL": "https://www.tipsyfoxescapes.ca"
  },
  "rewrites": [
    { "source": "/webhook", "destination": "/api/webhook" },
    { "source": "/version", "destination": "/api/version" },
    { "source": "/api/auth/oauth/(google|facebook|github)/start", "destination": "/api/oauth?kind=start&provider=$1" },
    { "source": "/api/auth/oauth/(google|facebook|github)/callback", "destination": "/api/oauth?kind=callback&provider=$1" },
    { "source": "/api/auth/oauth/complete", "destination": "/api/oauth?kind=complete" },
    { "source": "/api/(.*)", "destination": "/api?path=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/health.js": {
      "maxDuration": 10
    },
    "api/version.js": {
      "maxDuration": 10
    },
    "api/oauth.js": {
      "maxDuration": 30,
      "includeFiles": "api/oauth.cjs"
    },
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "api/*.cjs"
    },
    "api/webhook.js": {
      "maxDuration": 10,
      "includeFiles": "api/oauth.cjs"
    }
  }
}