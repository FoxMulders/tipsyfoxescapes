# Base URL the *browser* uses to reach the OAuth callback. Must match the public app origin.
# Local (Vite :5173): http://localhost:5173
# Vercel: https://your-app.vercel.app  (same URL users open; /api is proxied to this backend)
# Register the exact redirect URI in Google Cloud Console, e.g.:
#   http://localhost:5173/api/auth/oauth/google/callback
#   https://your-app.vercel.app/api/auth/oauth/google/callback
AUTH_CALLBACK_BASE_URL=http://localhost:5173

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional — same pattern: FACEBOOK_CLIENT_ID, FACEBOOK_CLIENT_SECRET, GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET

# Comma-separated emails that always get full access without a paid subscription (ops / owner accounts).
ADMIN_EMAILS=your-admin@example.com

# Optional salt for hashing client IPs in usage-ledger.json (change in production).
USAGE_HASH_SALT=change-me-in-production

# Dev / manual fulfillment (admin accounts only): POST /api/billing/activate-test with body
# { "activationKey": "<this value>", "roomsToAdd": 10 } while signed in as an admin user (adds room slots; not time-based).
SUBSCRIPTION_ACTIVATION_KEY=dev-change-me

# Square payments (customer checkout for room packs). Use Sandbox credentials for local dev.
# Create an app at https://developer.squareup.com — enable Checkout / Payments, copy access token + location id.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
# Public URL where users land after checkout (Vite dev: http://localhost:5173)
APP_PUBLIC_URL=http://localhost:5173
# Webhook: in Square Developer Dashboard subscribe to payment.updated (and/or payment.created).
# Notification URL must match exactly (use ngrok or similar for local webhook testing).
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-host.example/api/billing/square/webhook

# Optional: legacy manual fulfillment when not using Square (server-to-server).
BILLING_WEBHOOK_SECRET=
