{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && npm ci --prefix ../backend",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "env": {
    "SKIP_VERSION_BUMP": "1"
  },
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
