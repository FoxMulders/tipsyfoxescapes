# Local dev: leave unset — Vite proxies /api to http://127.0.0.1:3001 (see vite.config.ts).

# Vercel production: set BACKEND_URL in the Vercel dashboard (not in this file).
# Example: BACKEND_URL=https://api.yourdomain.com
# The serverless handler at api/[...path].js forwards /api/* to that origin.
