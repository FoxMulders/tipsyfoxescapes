# Local dev: leave unset — Vite proxies /api to http://127.0.0.1:3001 (see vite.config.ts).

# Production on Vercel: set these in Vercel → Project → Environment Variables
# (not in this file). The Express API runs as serverless functions via api/[...path].js.
#
# Required for Google login:
#   AUTH_CALLBACK_BASE_URL=https://www.tipsyfoxescapes.ca
#   GOOGLE_CLIENT_ID=...
#   GOOGLE_CLIENT_SECRET=...
#   OAUTH_STATE_SECRET=long-random-string
#
# Optional: USAGE_HASH_SALT, SQUARE_*, ADMIN_EMAILS, etc. (see ../backend/.env.example)
