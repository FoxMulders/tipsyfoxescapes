{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && npm ci --prefix backend && npm ci --prefix frontend",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist",
  "env": {
    "SKIP_VERSION_BUMP": "1",
    "DATA_DIR": "/tmp/erb-data",
    "OAUTH_GOOGLE_ENABLED": "1"
  },
  "rewrites": [
    { "source": "/webhook", "destination": "/api/webhook" },
    { "source": "/version", "destination": "/api/version" },
    { "source": "/api/(.*)", "destination": "/api?path=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/health.js": {
      "maxDuration": 10
    },
    "api/version.js": {
      "maxDuration": 10
    },
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "api/*.cjs"
    },
    "api/webhook.js": {
      "maxDuration": 10,
      "includeFiles": "api/oauth.cjs"
    },
    "api/auth/oauth/[provider]/start.js": {
      "maxDuration": 15,
      "includeFiles": "api/oauth.cjs"
    },
    "api/auth/oauth/[provider]/callback.js": {
      "maxDuration": 30,
      "includeFiles": "api/oauth.cjs"
    }
  }
}