{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && npm ci --prefix Dev/app/backend && npm ci --prefix Dev/app/frontend",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "Dev/app/frontend/dist",
  "env": {
    "SKIP_VERSION_BUMP": "1"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/api", "destination": "/api" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
